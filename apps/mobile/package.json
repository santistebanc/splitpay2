{
  "name": "@splitpay/mobile",
  "version": "0.0.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "start": "node ../../node_modules/expo/bin/cli start",
    "start:tunnel": "node ../../node_modules/expo/bin/cli start --tunnel",
    "android": "node ../../node_modules/expo/bin/cli run:android",
    "web": "node ../../node_modules/expo/bin/cli start --web --port 8081",
    "web:env": "node ../../node_modules/expo/bin/cli start --web --port 8081",
    "web:sync": "bash ../../scripts/with-env.sh ../../env/local.keys node ../../node_modules/expo/bin/cli start --web --port 8081",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@azure/core-asynciterator-polyfill": "^1.0.2",
    "@journeyapps/react-native-quick-sqlite": "^2.5.2",
    "@journeyapps/wa-sqlite": "^1.7.0",
    "@powersync/adapter-sql-js": "^0.0.18",
    "@powersync/common": "^1.54.0",
    "@powersync/react-native": "^1.35.4",
    "@powersync/web": "^1.38.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "@splitpay/ledger": "*",
    "@supabase/supabase-js": "^2.95.3",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-crypto": "~56.0.4",
    "expo-file-system": "~56.0.8",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-paper": "^5.15.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@babel/plugin-transform-async-generator-functions": "^7.29.7",
    "@powersync/node": "^0.18.8",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "better-sqlite3": "^12.10.0"
  }
