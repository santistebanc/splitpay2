{
  "expo": {
    "name": "SplitPay",
    "slug": "splitpay",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "splitpay",
    "userInterfaceStyle": "automatic",
    "ios": {
      "userInterfaceStyle": "automatic"
    },
    "android": {
      "userInterfaceStyle": "automatic",
      "usesCleartextTraffic": true,
      "package": "com.santistebanc.splitpay"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-status-bar",
      "@journeyapps/react-native-quick-sqlite",
      "./plugins/withGradleMemory.js"
    ]
  }
}
