{
  "name": "splitpay",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "verify": "npm run typecheck && npm run format:check && npm run test && npm run test:e2e",
    "ci": "npm run verify",
    "web": "npm run web:sync --workspace=@splitpay/mobile",
    "mobile": "npm run start --workspace=@splitpay/mobile",
    "mobile:tunnel": "npm run start:tunnel --workspace=@splitpay/mobile",
    "mobile:dev": "bash scripts/start-mobile-dev.sh",
    "mobile:remote": "bash scripts/with-env.sh env/dev.local npm run start:tunnel --workspace=@splitpay/mobile",
    "mobile:sync": "bash scripts/start-mobile-sync.sh",
    "web:dev": "bash scripts/with-env.sh env/dev.local npm run web:env --workspace=@splitpay/mobile",
    "deploy:dev": "bash scripts/deploy-dev.sh",
    "check:remote-dev": "bash scripts/check-remote-dev.sh",
    "mobile:android": "npm run android --workspace=@splitpay/mobile",
    "mobile:android:wsl": "bash scripts/mobile-android-wsl.sh",
    "mobile:android:setup": "bash scripts/setup-android-sdk-wsl.sh",
    "mobile:android:win": "bash scripts/mobile-android-windows.sh",
    "mobile:adb:qr": "npx --yes adb-qr@latest qr",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:sync": "vitest run powersync-sync.test.ts",
    "test:e2e:sync": "PLAYWRIGHT_SYNC_E2E=1 playwright test e2e/two-device-sync.spec.ts",
    "test:clean": "bash scripts/clean-test-dbs.sh",
    "test:e2e": "CI=1 playwright test",
    "supabase:reset": "supabase db reset",
    "powersync:start": "bash scripts/start-powersync.sh",
    "prepare": "husky",
    "postinstall": "node scripts/patch-react-native-gradle.js"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript": "^5.8.3",
    "vitest": "^4.1.8"
  }
}
